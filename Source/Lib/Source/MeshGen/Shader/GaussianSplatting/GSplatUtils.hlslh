#pragma once

#include "Utils.hlslh"

static const uint32_t ImgTileX = 16;
static const uint32_t ImgTileY = 16;

void GetRect(float2 pos, uint32_t radius, out uint32_t2 rect_min, out uint32_t2 rect_max, uint32_t2 grid)
{
    rect_min = uint32_t2(clamp((pos - radius) / uint32_t2(ImgTileX, ImgTileY), 0, grid));
    rect_max = uint32_t2(clamp(DivUp(uint32_t2(pos + radius), uint32_t2(ImgTileX, ImgTileY)), 0, grid));
}
